{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "apps/backend/src/index.ts"],
      "port": 3001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "apps/frontend"],
      "port": 5173
    },
    {
      "name": "backend-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/backend/dist/index.js"],
      "port": 3001
    }
  ]
}
