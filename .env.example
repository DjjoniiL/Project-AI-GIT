# Скопируйте в .env и заполните реальными значениями. .env не коммитится (см. .gitignore).

# Ключ приложения VibeCode (скоупы: crm, disk, placement)
VIBE_APP_KEY=

# Базовый URL VibeCode API — опционально, по умолчанию https://vibecode.bitrix24.tech
VIBE_API_BASE_URL=

# ID папки на Диске Битрикс24 для файлов макета (GET /v1/storages -> rootFolderId)
VIBE_LAYOUT_FOLDER_ID=

# Setup-скрипты остановятся, если ключ относится к другому порталу.
VIBE_EXPECTED_PORTAL=vibecode01.bitrix24.ru

# Актуальный URL приложения и сервер VibeCode для живых проверок/placement.
VIBE_APP_URL=https://app-5670766a17c1.vibecode.bitrix24.tech
VIBE_SERVER_ID=e95ca529-f434-4432-bbb8-a7e0e8f85837

# Личный ключ нужен только для owner-only server probes/access-token minting.
# Не коммитить реальное значение.
VIBE_PERSONAL_API_KEY=

# Порт backend-сервера при локальной разработке
PORT=3001
